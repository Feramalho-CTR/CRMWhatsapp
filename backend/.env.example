# Exemplo de .env para o backend
# Configure a sua conexão com o Firebase/Firestore
# Duas opções:
# 1) Defina a variável de ambiente GOOGLE_APPLICATION_CREDENTIALS apontando para o arquivo JSON da conta de serviço
# 2) Ou defina FIREBASE_CREDENTIALS_JSON com o conteúdo do JSON da conta de serviço (útil para CI/containers)
FIREBASE_PROJECT=seu-projeto-firebase
# FIREBASE_CREDENTIALS_JSON='{...conteudo do json...}'
# SECRET_KEY é usado para assinar JWTs. Troque por uma chave forte em produção.
SECRET_KEY=troque_esta_chave_para_producao

# Variáveis opcionais relacionadas ao WhatsApp (se aplicável)
# ACCESS_TOKEN=SEU_TOKEN_DE_ACESSO_DO_WHATSAPP_CLOUD
# PHONE_NUMBER_ID=ID_DO_NUMERO_DE_TELEFONE
# BUSINESS_ACCOUNT_ID=ID_DA_CONTA_BUSINESS
# WEBHOOK_VERIFY_TOKEN=um_token_secreto_para_verificacao_do_webhook
# Opcional: credenciais do App (para obter access token via client_credentials)
# CLIENT_ID=seu_client_id_app
# CLIENT_SECRET=seu_client_secret_app
# Opcional: integração via n8n
# USE_N8N=false
# N8N_WEBHOOK_URL=https://seu-n8n.example/webhook

# Como testar localmente:
# 1) Preencha ACCESS_TOKEN e PHONE_NUMBER_ID se desejar enviar mensagens reais via WhatsApp Cloud API.
# 2) Defina WEBHOOK_VERIFY_TOKEN e configure o webhook no painel do Meta/WhatsApp apontando para:
#    https://<seu-dominio>/api/whatsapp/webhook  (ou http://localhost:8000/api/whatsapp/webhook para testes locais com ngrok)
# 3) Para verificação, o Meta fará uma requisição GET com query params: hub.mode=subscribe, hub.challenge, hub.verify_token